  .page { max-width: 1120px; margin: 0 auto; padding: 35px 36px 70px; }.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px; }.page-header h2 { margin: 4px 0 0; font-size: 22px; letter-spacing: 0; }.metric-row { display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--line); border-radius: 6px; margin-bottom: 22px; }.metric-row > div { min-height: 90px; display: grid; align-content: center; padding: 16px 20px; border-right: 1px solid var(--line); }.metric-row > div:last-child { border: 0; }.metric-row strong { font-size: 23px; }.metric-row span { font-size: 11px; color: var(--muted); }.metric-row .danger strong { color: var(--red); }.list { border: 1px solid var(--line); border-radius: 6px; overflow: hidden; }.list-row { width: 100%; min-height: 56px; padding: 9px 14px; border: 0; border-bottom: 1px solid var(--line); background: white; display: flex; align-items: center; gap: 12px; text-align: left; color: var(--ink); }.list-row:last-child { border-bottom: 0; }.list-row:hover:is(button) { background: #fafbfa; }.list-row > :global(svg):first-child { color: var(--muted); width: 17px; }.list-row > :global(svg):last-child { margin-left: auto; width: 15px; color: var(--muted); }.list-row span:not(.commit) { min-width: 0; display: grid; gap: 3px; }.list-row strong { font-size: 12px; }.list-row small { color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }.history-layout,.schema-layout { display: grid; grid-template-columns: minmax(300px, .9fr) minmax(400px, 1.1fr); gap: 20px; }.commit { font: 11px ui-monospace, monospace; color: var(--green); background: var(--green-soft); padding: 3px 5px; border-radius: 3px; }.diff { margin: 0; padding: 16px; min-height: 450px; overflow: auto; background: #26312b; color: #e2e9e4; border-radius: 6px; font: 11px/1.6 ui-monospace, monospace; }.schema-editor { display: grid; gap: 12px; align-content: start; }.code { font: 12px/1.6 ui-monospace, monospace; }.role-select { width: 115px; margin-left: auto; }.dialog-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 18px; } dialog { border: 1px solid var(--line); border-radius: 7px; padding: 0; box-shadow: 0 18px 50px rgba(0,0,0,.2); } dialog::backdrop { background: rgba(26,32,28,.35); } dialog form { width: 360px; display: grid; gap: 14px; padding: 22px; } dialog h3 { margin: 0 0 4px; font-size: 17px; } #dialog-extra { display: grid; gap: 14px; }
  .mobile-only { display: none; }
  @media (max-width: 880px) { .workspace { grid-template-columns: 52px minmax(0,1fr); }.library { position: fixed; z-index: 10; left: 52px; top: 0; bottom: 0; width: min(290px, calc(100vw - 52px)); transform: translateX(calc(-100% - 52px)); box-shadow: 12px 0 30px rgba(0,0,0,.12); transition: transform .18s ease; }.library.open { transform: translateX(0); }.main { grid-column: 2; }.mobile-only { display: inline-grid; }.topbar { justify-content: initial; gap: 8px; }.top-actions { margin-left: auto; }.editor-layout { height: auto; grid-template-columns: 1fr; }.document-heading { padding: 25px 22px 16px; align-items: start; flex-direction: column; }.body-editor { min-height: 480px; padding: 22px; }.properties { border-left: 0; border-top: 1px solid var(--line); }.page { padding: 28px 20px 60px; }.history-layout,.schema-layout { grid-template-columns: 1fr; }.metric-row { grid-template-columns: 1fr 1fr 1fr; }.metric-row > div { padding: 12px; }.title-input { font-size: 21px; } }

  /* Usability pass: one labeled sidebar and an optional document inspector. */
  .workspace { grid-template-columns: 276px minmax(0, 1fr); background: var(--paper); }
  .sidebar { min-width: 0; display: flex; flex-direction: column; border-right: 1px solid var(--line); background: #f7f8f6; }
  .brand-header { min-height: 72px; display: flex; align-items: center; gap: 11px; padding: 14px 16px; border-bottom: 1px solid var(--line); }
  .brand-mark { width: 36px; height: 36px; display: grid; place-items: center; border-radius: 6px; color: white; background: #26312b; }
  .brand-mark :global(svg) { width: 19px; }
  .brand-header > span:last-child { display: grid; gap: 2px; }
  .brand-header strong { font-size: 15px; }
  .brand-header small { color: var(--muted); font-size: 11px; }
  .primary-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; padding: 10px 10px 12px; border-bottom: 1px solid var(--line); }
  .rail-button { width: auto; height: 36px; padding: 0 9px; display: flex; align-items: center; justify-content: flex-start; gap: 8px; border: 1px solid transparent; border-radius: 5px; color: #56605a; background: transparent; font-size: 12px; font-weight: 650; }
  .rail-button :global(svg) { width: 16px; }
  .rail-button:hover { border-color: var(--line); color: var(--ink); background: white; }
  .rail-button.active { color: #14573e; background: var(--green-soft); border-color: #cfe3d7; }
  .rail-button .dot { position: static; width: 7px; height: 7px; margin-left: auto; }
  .library-header { height: 46px; padding: 10px 12px 6px 16px; }
  .library-header strong { font-size: 12px; color: var(--muted); text-transform: uppercase; }
  .search-wrap { height: 38px; margin: 0 12px 12px; padding: 0 10px; border-color: #d3d8d4; }
  .search-wrap input { font-size: 13px; }
  .document-tree { min-height: 0; padding: 0 8px 14px; }
  .tree-folder { height: 31px; padding: 0 10px; font-size: 11px; }
  .tree-document { min-height: 40px; grid-template-columns: 18px minmax(0,1fr) 17px; gap: 8px; padding: 7px 9px 7px 17px; font-size: 13px; }
  .tree-document.active { background: #dfece4; box-shadow: inset 3px 0 #207454; }
  .sidebar-footer { min-height: 58px; display: flex; align-items: center; gap: 9px; padding: 10px 12px; border-top: 1px solid var(--line); background: white; }
  .user-avatar { width: 32px; height: 32px; display: grid; place-items: center; border-radius: 50%; color: #195239; background: #dcebe2; font-size: 12px; font-weight: 800; }
  .user-summary, .repo-summary { display: grid; gap: 1px; }
  .user-summary strong { font-size: 12px; text-transform: capitalize; }
  .user-summary small, .repo-summary small, .repo-summary > span { color: var(--muted); font-size: 10px; }
  .repo-summary { margin-left: auto; text-align: right; }
  .main { grid-column: 2; min-height: 0; height: 100%; overflow: hidden; }
  .topbar { height: 62px; flex-basis: 62px; padding: 0 22px; }
  .breadcrumbs { font-size: 13px; }
  .editor-layout { position: relative; min-height: 0; grid-template-columns: minmax(0, 1fr); overflow: hidden; }
  .editor-layout.inspector-open { grid-template-columns: minmax(420px, 1fr) 380px; }
  .editor-main { min-height: 0; }
  .document-heading { width: min(920px, 100%); margin: 0 auto; padding: 42px 48px 23px; }
  .document-heading > div { gap: 13px; }
  .title-input { font-size: 30px; line-height: 1.2; }
  .body-editor { width: min(920px, 100%); margin: 0 auto; min-height: 560px; padding: 34px 48px 90px; color: #2b302d; font: 16px/1.75 Inter, ui-sans-serif, system-ui, sans-serif; }
  .properties { display: none; min-width: 0; min-height: 0; height: 100%; overflow-x: hidden; overflow-y: auto; overscroll-behavior: contain; background: #fbfcfb; }
  .inspector-open .properties { display: flex; }
  .inspector-header { position: sticky; z-index: 2; top: 0; min-height: 62px; flex: 0 0 62px; display: flex; align-items: center; justify-content: space-between; padding: 10px 16px 10px 20px; border-bottom: 1px solid var(--line); background: white; }
  .inspector-header > div { display: grid; gap: 3px; }
  .inspector-header strong { font-size: 15px; }
  .inspector-fields, .governance-section, .advanced-metadata, .properties > .validation-errors { flex: 0 0 auto; }
  .inspector-fields { display: grid; gap: 17px; padding: 20px; border-bottom: 1px solid var(--line); background: white; }
  .inspector-fields .input, .inspector-fields .textarea { font-size: 13px; }
  .governance-section { padding-bottom: 12px; border-bottom: 1px solid var(--line); }
  .resolved-grid { display: grid; gap: 0; padding: 5px 20px 12px; }
  .resolved-grid > div { min-height: 34px; display: grid; grid-template-columns: 1fr 1.2fr; align-items: center; gap: 12px; border-bottom: 1px solid #e7eae7; }
  .resolved-grid > div:last-child { border-bottom: 0; }
  .resolved-grid dt { color: var(--muted); font-size: 11px; text-transform: capitalize; }
  .resolved-grid dd { margin: 0; font-size: 12px; font-weight: 650; overflow-wrap: anywhere; }
  .advanced-metadata { padding: 15px 20px 24px; }
  .advanced-metadata summary { cursor: pointer; color: var(--muted); font-size: 12px; font-weight: 700; }
  .advanced-metadata[open] summary { margin-bottom: 12px; }
  .metadata-editor { min-height: 260px; padding: 12px; border: 1px solid var(--line); border-radius: 5px; font-size: 12px; }
  .page { padding-top: 42px; }
  .page-header h2 { font-size: 26px; }
  .list-row strong { font-size: 13px; }
  .list-row small { font-size: 11px; }

  @media (max-width: 900px) {
    .workspace { grid-template-columns: minmax(0, 1fr); }
    .sidebar { position: fixed; z-index: 10; inset: 0 auto 0 0; width: min(300px, calc(100vw - 44px)); transform: translateX(-105%); box-shadow: 12px 0 30px rgba(0,0,0,.12); transition: transform .18s ease; }
    .sidebar.open { transform: translateX(0); }
    .main { grid-column: 1; }
    .mobile-only { display: inline-grid; }
    .topbar { height: 58px; flex-basis: 58px; padding: 0 12px; }
    .breadcrumbs > span, .breadcrumbs :global(svg) { display: none; }
    .editor-layout.inspector-open { grid-template-columns: 1fr; }
    .editor-layout { overflow: visible; }
    .document-heading { padding: 30px 24px 20px; align-items: start; flex-direction: column; }
    .title-input { font-size: 25px; }
    .body-editor { min-height: 520px; padding: 26px 24px 70px; font-size: 15px; }
    .inspector-open .properties { height: auto; overflow: visible; border-left: 0; border-top: 1px solid var(--line); }
    .history-layout, .schema-layout { grid-template-columns: 1fr; }
  }

  @media (max-width: 560px) {
