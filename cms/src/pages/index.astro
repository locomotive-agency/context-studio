    #toggle-inspector { font-size: 0; gap: 0; }
    #toggle-inspector :global(svg) { width: 17px; }
    .path-label { white-space: normal; overflow-wrap: anywhere; }
    .metric-row { grid-template-columns: repeat(3, 1fr); }
    .metric-row > div { min-height: 74px; padding: 10px; }
  }

  .workspace { grid-template-columns: 224px minmax(0, 1fr); }
  .primary-nav { grid-template-columns: 1fr; padding: 12px 10px; }
  .rail-button { height: 40px; font-size: 13px; }
  .sidebar-context { display: grid; gap: 4px; margin: 14px 12px; padding: 13px 12px; border: 1px solid var(--line); border-radius: 6px; background: white; }
  .sidebar-context strong { font-size: 13px; }
  .sidebar-context > span:last-child { color: var(--muted); font-size: 11px; }
  .sidebar-footer { margin-top: auto; }
  .documents-header { align-items: end; }
  .documents-header p { margin: 6px 0 0; color: var(--muted); font-size: 13px; }
  .document-browser { max-width: 1460px; }
  .document-toolbar { min-height: 58px; display: flex; align-items: center; gap: 16px; padding: 9px 12px; border: 1px solid var(--line); border-bottom: 0; border-radius: 7px 7px 0 0; background: #fafbfa; }
  .document-toolbar .search-wrap { width: min(480px, 100%); margin: 0; }
  .result-count { margin-left: auto; color: var(--muted); font-size: 12px; }
  .browser-layout { min-height: 560px; display: grid; grid-template-columns: 240px minmax(0, 1fr); border: 1px solid var(--line); border-radius: 0 0 7px 7px; overflow: hidden; }
  .folder-browser { min-width: 0; padding: 14px 10px; border-right: 1px solid var(--line); background: #f7f8f7; }
  .section-label { padding: 0 10px 9px; color: var(--muted); font-size: 10px; font-weight: 800; text-transform: uppercase; }
  .folder-list { display: grid; gap: 2px; }
  .folder-row { width: 100%; min-height: 38px; display: grid; grid-template-columns: 17px minmax(0, 1fr) auto; align-items: center; gap: 8px; padding: 6px 9px 6px calc(9px + var(--depth) * 14px); border: 1px solid transparent; border-radius: 5px; color: #4d5651; background: transparent; text-align: left; font-size: 12px; }
  .folder-row svg { width: 16px; color: #77817b; }
  .folder-row span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .folder-row small { color: var(--muted); font-size: 10px; font-variant-numeric: tabular-nums; }
  .folder-row:hover { border-color: var(--line); background: white; }
  .folder-row.active { color: #14573e; border-color: #c7dfd1; background: var(--green-soft); font-weight: 700; }
  .file-browser { min-width: 0; display: flex; flex-direction: column; background: white; }
  .file-table-header, .file-row { display: grid; grid-template-columns: minmax(260px, 1.8fr) minmax(130px, .7fr) 100px 24px; align-items: center; gap: 16px; }
  .file-table-header { min-height: 38px; padding: 0 16px; border-bottom: 1px solid var(--line); color: var(--muted); background: #fafbfa; font-size: 10px; font-weight: 800; text-transform: uppercase; }
  .file-table { flex: 1; }
