---
import "../styles/global.css";
import "../styles/context-studio.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Context Studio" />
    <title>Context Studio</title>
  </head>
  <body>
    <section id="login" class="login-shell">
      <form id="login-form" class="login-panel">
        <div class="mark"><i data-lucide="braces"></i></div>
        <div><h1>Context Studio</h1><p id="login-copy">Governed context workspace</p></div>
        <div class="field local-login-field"><label for="username">Username</label><input class="input" id="username" name="username" placeholder="admin" autocomplete="username" /></div>
        <div class="field local-login-field"><label for="password">Password</label><input class="input" id="password" name="password" type="password" placeholder="admin123" autocomplete="current-password" /></div>
        <p id="login-error" class="form-error hidden"></p>
        <button id="local-login-button" class="button primary login-button" type="submit">Sign in</button>
        <button id="github-login-button" class="button primary login-button hidden" type="button"><i data-lucide="git-branch"></i>Sign in with GitHub</button>
      </form>
    </section>

    <div id="workspace" class="workspace hidden">
      <aside class="sidebar" id="library">
        <header class="brand-header">
          <span class="brand-mark"><i data-lucide="braces"></i></span>
          <span><strong>Context Studio</strong><small>Governed context</small></span>
        </header>
        <nav class="primary-nav" aria-label="Workspace">
          <button class="rail-button active" data-view="documents"><i data-lucide="files"></i><span>Documents</span></button>
          <button class="rail-button" data-view="collections"><i data-lucide="database"></i><span>Collections</span></button>
          <button class="rail-button" data-view="test-bench"><i data-lucide="test-tube-2"></i><span>MCP Test Tool</span></button>
          <button class="rail-button" data-view="validation"><i data-lucide="shield-check"></i><span>Validation</span><span id="validation-dot" class="dot hidden"></span></button>
          <button class="rail-button" data-view="history"><i data-lucide="history"></i><span>History</span></button>
          <button class="rail-button" data-view="scopes"><i data-lucide="network"></i><span>Scopes</span></button>
          <button class="rail-button editor-only" data-view="schemas"><i data-lucide="brackets"></i><span>Schemas</span></button>
          <button class="rail-button admin-only" data-view="users"><i data-lucide="users"></i><span>Users</span></button>
        </nav>
        <div class="sidebar-context">
          <span class="eyebrow">Repository</span>
          <strong id="document-count">0 documents</strong>
          <span id="git-sha">Git</span>
        </div>
        <footer class="sidebar-footer">
          <span class="user-avatar" id="user-initial">A</span>
          <span class="user-summary"><strong id="user-name">Admin</strong><small id="user-role">admin</small></span>
        </footer>
      </aside>

      <main class="main">
        <header class="topbar">
          <button id="mobile-library" class="icon-button mobile-only" title="Open navigation"><i data-lucide="menu"></i></button>
          <div class="breadcrumbs"><span>Context Studio</span><i data-lucide="chevron-right"></i><strong id="current-location">Documents</strong></div>
          <div class="top-actions">
            <span id="save-state" class="save-state"></span>
            <button id="move-document" class="button editor-only hidden"><i data-lucide="folder"></i>Move</button>
            <button id="document-history" class="button hidden"><i data-lucide="history"></i>History</button>
            <button id="toggle-inspector" class="button hidden"><i data-lucide="panel-right"></i>Details</button>
            <button id="save-document" class="button primary editor-only hidden"><i data-lucide="save"></i>Save</button>
          </div>
        </header>

        <section id="view-documents" class="view active">
          <div id="document-browser" class="document-browser page">
            <div class="page-header documents-header">
              <div><span class="eyebrow">Repository</span><h2>Documents</h2><p id="browser-summary">Browse context files by folder.</p></div>
              <div class="document-actions">
                <button id="delete-folder" class="button danger editor-only hidden" type="button"><i data-lucide="trash-2"></i>Delete folder</button>
                <button id="toggle-okf-import" class="button editor-only"><i data-lucide="upload"></i>Import OKF folder</button>
                <button id="new-folder-documents" class="button editor-only"><i data-lucide="folder-plus"></i>New folder</button>
                <button id="new-menu" class="button primary editor-only"><i data-lucide="file-plus-2"></i>New document</button>
              </div>
            </div>
            <div id="okf-import-panel" class="import-panel hidden">
              <input id="okf-import-folder" class="hidden" type="file" multiple />
              <div class="field"><label for="okf-import-folder-label">Folder</label><input id="okf-import-folder-label" class="input" value="No folder selected" readonly /></div>
              <div class="import-actions">
                <button id="choose-okf-import" class="button" type="button"><i data-lucide="folder"></i>Choose folder</button>
                <button id="scan-okf-import" class="button" type="button"><i data-lucide="file-search"></i>Scan</button>
                <button id="apply-okf-import" class="button primary" type="button" disabled><i data-lucide="upload"></i>Import</button>
              </div>
              <pre id="okf-import-report" class="json-output">No scan yet.</pre>
            </div>
            <div class="document-toolbar">
              <div class="search-wrap"><i data-lucide="search"></i><input id="document-search" placeholder="Search names, paths, and types" /></div>
              <span id="result-count" class="result-count"></span>
            </div>
            <div class="browser-layout">
              <aside class="folder-browser">
                <div class="section-label">Folders</div>
                <div id="folder-list" class="folder-list"></div>
              </aside>
              <div class="file-browser">
                <div class="file-table-header"><span>Name</span><span>Type</span><span>OKF</span><span></span></div>
                <div id="document-list" class="file-table"></div>
                <div class="pagination"><button id="previous-page" class="button"><i data-lucide="chevron-left"></i>Previous</button><span id="page-status"></span><button id="next-page" class="button">Next<i data-lucide="chevron-right"></i></button></div>
              </div>
            </div>
          </div>
          <div id="document-editor" class="editor-layout hidden">
            <article class="editor-main">
              <div class="document-heading">
                <div class="document-heading-main"><button id="back-to-documents" class="back-link"><i data-lucide="arrow-left"></i>Documents</button><input id="document-title" class="title-input" aria-label="Document title" /></div>
                <div class="document-heading-meta"><span id="document-status" class="badge certification-badge valid" title="OKF validation passed"><i data-lucide="shield-check"></i><span>OKF valid</span></span><span id="document-path" class="path-label"></span></div>
              </div>
              <div id="editor-mode-bar" class="editor-mode-bar hidden"><div class="editor-mode-bar-inner"><div id="editor-modes" class="segmented"><button class="active" data-editor-mode="raw">Raw</button><button data-editor-mode="preview">Preview</button><button data-editor-mode="split">Split</button></div></div></div>
              <div id="content-editor" class="content-editor mode-raw"><textarea id="document-body" class="body-editor" spellcheck="true" aria-label="Document content"></textarea><article id="document-preview" class="document-preview"></article></div>
            </article>
            <aside class="properties">
              <div class="inspector-header"><div><span class="eyebrow">Document</span><strong>Details</strong></div><button id="close-inspector" class="icon-button" title="Close details"><i data-lucide="x"></i></button></div>
              <div class="inspector-fields">
                <div class="field"><label for="meta-description">Description</label><textarea id="meta-description" class="textarea" rows="3"></textarea></div>
                <div class="field"><label for="meta-tags">Tags</label><input id="meta-tags" class="input" placeholder="brand, writing" /></div>
              </div>
              <div id="document-metadata-fields" class="metadata-fields inspector-metadata"></div>
              <div id="validation-errors" class="validation-errors hidden"></div>
              <div class="governance-section"><div class="panel-title"><strong>Resolved governance</strong><span>Inherited</span></div><div id="resolved-metadata" class="resolved-grid"></div></div>
              <details class="advanced-metadata"><summary>Advanced frontmatter</summary><textarea id="frontmatter-editor" class="metadata-editor" spellcheck="false" aria-label="YAML frontmatter"></textarea></details>
              <div class="inspector-actions editor-only"><button id="delete-document" class="button danger" type="button"><i data-lucide="trash-2"></i>Delete document</button></div>
            </aside>
          </div>
        </section>

        <section id="view-collections" class="view">
          <div class="page">
            <div class="page-header">
              <div><span class="eyebrow">Supporting sources</span><h2>Collections</h2><p class="page-subtitle">Buckets of source files indexed for retrieval through OKF supporting sources.</p></div>
              <button id="new-collection" class="button primary editor-only"><i data-lucide="plus"></i>New collection</button>
            </div>
            <div class="collection-layout">
              <aside>
                <div id="collection-list" class="list"></div>
              </aside>
              <section class="collection-detail">
                <div class="collection-detail-header">
                  <div><span class="eyebrow">Selected collection</span><strong id="collection-title">No collection selected</strong><small id="collection-description"></small></div>
                  <div>
                    <input id="collection-files" class="hidden" type="file" multiple />
                    <button id="upload-collection-files" class="button editor-only" type="button"><i data-lucide="upload"></i>Add files</button>
                  </div>
                </div>
                <div id="collection-documents" class="file-table"></div>
              </section>
            </div>
          </div>
        </section>

        <section id="view-test-bench" class="view">
          <div class="page mcp-test-page">
            <div class="page-header">
              <div><span class="eyebrow">MCP tools</span><h2>MCP Test Tool</h2><p class="page-subtitle">Retrieval tool checks.</p></div>
            </div>
            <div class="bench-shell">
              <section class="bench-command-panel">
                <form id="bench-form" class="bench-form">
                  <div class="field"><label for="bench-tool">Tool</label><select id="bench-tool" class="select"></select></div>
                  <div id="bench-fields" class="bench-fields"></div>
                  <button class="button primary" type="submit"><i data-lucide="file-search"></i>Run</button>
                </form>
                <details class="bench-raw-panel">
                  <summary><span>Request JSON</span><i data-lucide="chevron-down"></i></summary>
                  <pre id="bench-request" class="json-output compact">{}</pre>
                </details>
              </section>
              <section class="bench-response-panel">
                <div id="bench-results" class="bench-results"><div class="empty">No result yet.</div></div>
                <details class="bench-raw-panel">
                  <summary><span>Response JSON</span><i data-lucide="chevron-down"></i></summary>
                  <pre id="bench-response" class="json-output">{}</pre>
                </details>
              </section>
            </div>
          </div>
        </section>

        <section id="view-validation" class="view"><div class="page"><div class="page-header"><div><span class="eyebrow">Quality</span><h2>OKF validation</h2></div><button id="refresh-validation" class="icon-button" title="Refresh"><i data-lucide="refresh-cw"></i></button></div><div id="validation-summary" class="metric-row"></div><div id="validation-list" class="list"></div></div></section>
        <section id="view-history" class="view"><div class="page"><div class="page-header"><div><span class="eyebrow">Local Git</span><h2>History</h2><p id="history-context" class="page-subtitle">Repository changes</p></div></div><div class="history-layout"><div id="history-list" class="list"></div><section class="revision-view"><div id="revision-empty" class="revision-empty">Select a revision</div><div id="revision-detail" class="hidden"><header class="revision-header"><div><span id="revision-hash" class="commit"></span><strong id="revision-title"></strong><small id="revision-meta"></small></div><button id="restore-revision" class="button hidden"><i data-lucide="rotate-ccw"></i>Restore this version</button></header><div id="diff-label" class="diff-label">Changes from the previous revision</div><div id="diff-view" class="diff-view"></div></div></section></div></div></section>
        <section id="view-scopes" class="view"><div class="page"><div class="page-header"><div><span class="eyebrow">Hierarchy</span><h2>Context scopes</h2></div><button id="new-scope" class="button primary admin-only"><i data-lucide="plus"></i>Add scope</button></div><div id="scope-list" class="scope-list"></div></div></section>
        <section id="view-schemas" class="view"><div class="page"><div class="page-header"><div><span class="eyebrow">Governance</span><h2>Folder metadata</h2><p class="page-subtitle">Defaults inherited by documents in each folder.</p></div><button id="new-folder" class="button editor-only"><i data-lucide="folder-plus"></i>New folder</button></div><div class="schema-layout"><div id="schema-list" class="list"></div><form id="schema-form" class="schema-editor"><div class="metadata-form-header"><span class="eyebrow">Selected folder</span><strong id="schema-label">Root</strong></div><div id="schema-metadata-fields" class="metadata-fields"></div><details class="advanced-metadata schema-advanced"><summary>Advanced YAML</summary><textarea id="schema-body" class="metadata-editor" spellcheck="false" aria-label="Folder schema YAML"></textarea></details><button id="save-schema" class="button primary editor-only" type="submit"><i data-lucide="save"></i>Save folder metadata</button></form></div></div></section>
        <section id="view-users" class="view"><div class="page"><div class="page-header"><div><span class="eyebrow">Access</span><h2>Users and roles</h2></div><button id="new-user" class="button"><i data-lucide="user-plus"></i>Add user</button></div><div id="user-list" class="list"></div></div></section>
      </main>
    </div>

    <div id="drawer-scrim" class="drawer-scrim hidden">
      <aside class="action-drawer" role="dialog" aria-modal="true" aria-labelledby="drawer-title">
        <header class="action-drawer-header"><div><span id="drawer-eyebrow" class="eyebrow">Create</span><h3 id="drawer-title">New document</h3></div><button id="close-drawer" class="icon-button" title="Close"><i data-lucide="x"></i></button></header>
        <form id="drawer-form"><div id="drawer-fields" class="action-drawer-body"></div><footer class="action-drawer-footer"><button id="delete-drawer-item" class="button danger hidden" type="button"><i data-lucide="trash-2"></i>Remove</button><span></span><button id="cancel-drawer" class="button" type="button">Cancel</button><button id="save-drawer" class="button primary" type="submit">Save</button></footer></form>
      </aside>
    </div>
    <div id="toast" class="toast hidden"></div>

    <script src="../scripts/context-studio.js"></script>
  </body>
</html>

