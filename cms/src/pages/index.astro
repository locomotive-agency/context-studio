  .pagination { min-height: 54px; display: flex; align-items: center; justify-content: flex-end; gap: 12px; padding: 8px 14px; border-top: 1px solid var(--line); background: #fafbfa; }
  .pagination span { min-width: 90px; color: var(--muted); font-size: 11px; text-align: center; }
  .button:disabled { cursor: default; opacity: .45; }
  button:focus { outline: none; }
  button:focus-visible, input:focus-visible, textarea:focus-visible, select:focus-visible { outline: 2px solid #5c967c; outline-offset: 2px; }
  .back-link { width: fit-content; display: inline-flex; align-items: center; gap: 6px; padding: 0; border: 0; color: var(--muted); background: transparent; font-size: 12px; font-weight: 700; }
  .back-link:hover { color: var(--green); }
  .back-link svg { width: 15px; }
  .document-heading-main { min-width: 0; display: grid; gap: 13px; }
  .segmented { display: inline-flex; align-items: center; padding: 2px; border: 1px solid var(--line); border-radius: 5px; background: #f4f6f4; }
  .segmented button { height: 28px; padding: 0 9px; border: 0; border-radius: 3px; color: var(--muted); background: transparent; font-size: 11px; font-weight: 700; }
  .segmented button.active { color: var(--ink); background: white; box-shadow: 0 1px 3px rgba(0,0,0,.09); }
  .editor-mode-bar { flex: 0 0 47px; border-bottom: 1px solid var(--line); background: #fafbfa; }
  .editor-mode-bar-inner { width: min(920px, 100%); height: 100%; display: flex; align-items: center; justify-content: flex-end; margin: 0 auto; padding: 0 48px; }
  .page-subtitle { margin: 5px 0 0; color: var(--muted); font-size: 12px; }
  .content-editor { min-height: 0; flex: 1; display: grid; overflow: hidden; }
  .content-editor .body-editor { height: 100%; min-height: 0; overflow: auto; }
  .document-preview { display: none; min-width: 0; min-height: 0; height: 100%; padding: 34px 48px 90px; overflow: auto; color: #2b302d; font-size: 15px; line-height: 1.7; }
  .document-preview > :first-child { margin-top: 0; }
  .document-preview pre { overflow: auto; padding: 14px; border: 1px solid var(--line); border-radius: 5px; background: #f6f7f6; font: 12px/1.6 ui-monospace, SFMono-Regular, Menlo, monospace; }
  .document-preview code { padding: 2px 4px; border-radius: 3px; background: #f0f2f0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .content-editor.mode-preview .body-editor { display: none; }
  .content-editor.mode-preview .document-preview { display: block; width: min(920px, 100%); margin: 0 auto; }
  .content-editor.mode-split { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
  .content-editor.mode-split .body-editor { width: 100%; border-right: 1px solid var(--line); }
  .content-editor.mode-split .document-preview { display: block; padding-left: 28px; padding-right: 28px; }
  .preview-error { padding: 12px; border: 1px solid #e6c3bf; border-radius: 5px; color: var(--red); background: var(--red-soft); font-size: 12px; }
  .scope-list { border: 1px solid var(--line); border-radius: 7px; overflow: hidden; background: white; }
  .scope-row { position: relative; min-height: 64px; display: grid; grid-template-columns: calc(var(--depth) * 24px) 20px 34px minmax(0, 1fr) 90px 36px; align-items: center; gap: 10px; padding: 8px 12px; border-bottom: 1px solid var(--line); }
  .scope-row:last-child { border-bottom: 0; }
  .scope-icon { width: 32px; height: 32px; display: grid; place-items: center; border-radius: 5px; color: #416552; background: var(--green-soft); }
  .scope-icon svg { width: 17px; }
  .drag-handle { height: 30px; display: grid; place-items: center; color: #939b96; cursor: grab; }
  .drag-handle:active { cursor: grabbing; }
  .drag-handle svg { width: 16px; }
  .scope-row.dragging { opacity: .45; }
  .scope-row.drop-before::before, .scope-row.drop-after::after { position: absolute; z-index: 2; right: 12px; left: 12px; height: 2px; content: ""; background: var(--green); }
  .scope-row.drop-before::before { top: -1px; }
  .scope-row.drop-after::after { bottom: -1px; }
  .scope-row.drop-inside { background: var(--green-soft); box-shadow: inset 0 0 0 2px #63a384; }
  .scope-name { min-width: 0; display: grid; gap: 3px; }
  .scope-name strong { font-size: 13px; }
  .scope-name small { overflow: hidden; color: var(--muted); font: 10px ui-monospace, SFMono-Regular, Menlo, monospace; text-overflow: ellipsis; white-space: nowrap; }
  .level-pill, .role-pill { width: fit-content; padding: 4px 7px; border-radius: 4px; color: #49534d; background: #eef0ee; font-size: 10px; font-weight: 750; text-transform: capitalize; }
  .role-pill { margin-left: auto; }
  .button.danger { color: var(--red); border-color: #e7c4c0; background: var(--red-soft); }
  .drawer-scrim { position: fixed; z-index: 30; inset: 0; display: flex; justify-content: flex-end; background: rgba(28, 34, 30, .28); }
  .action-drawer { width: min(420px, 100vw); height: 100%; display: flex; flex-direction: column; border-left: 1px solid var(--line); background: white; box-shadow: -14px 0 38px rgba(20, 29, 24, .14); }
  .action-drawer-header { min-height: 76px; display: flex; align-items: center; justify-content: space-between; padding: 14px 16px 14px 22px; border-bottom: 1px solid var(--line); }
  .action-drawer-header > div { display: grid; gap: 4px; }
  .action-drawer-header h3 { margin: 0; font-size: 18px; }
  #drawer-form { min-height: 0; flex: 1; display: flex; flex-direction: column; }
  .action-drawer-body { min-height: 0; flex: 1; display: grid; align-content: start; gap: 18px; padding: 22px; overflow: auto; }
  .action-drawer-footer { min-height: 66px; display: flex; align-items: center; justify-content: flex-end; gap: 9px; padding: 12px 16px; border-top: 1px solid var(--line); background: #fafbfa; }
  .action-drawer-footer > span { flex: 1; }
  .list-row > .icon-button { margin-left: 4px; }

  @media (max-width: 900px) {
    .workspace { grid-template-columns: minmax(0, 1fr); }
    .browser-layout { grid-template-columns: 190px minmax(0, 1fr); }
    .file-table-header, .file-row { grid-template-columns: minmax(230px, 1fr) 90px 24px; }
    .file-table-header > :nth-child(2), .file-type { display: none; }
    .content-editor { overflow: visible; }
    .content-editor .body-editor { min-height: 520px; }
    .document-preview { height: auto; overflow: visible; }
  }

  @media (max-width: 680px) {
    .document-browser.page { padding: 24px 14px 50px; }
    .documents-header { align-items: start; }
    .documents-header .button { font-size: 0; }
    .documents-header .button svg { margin: 0; }
    .document-toolbar { align-items: stretch; flex-direction: column; gap: 8px; }
    .result-count { margin-left: 2px; }
    .browser-layout { grid-template-columns: 1fr; }
    .folder-browser { max-height: 205px; overflow: auto; border-right: 0; border-bottom: 1px solid var(--line); }
    .file-table-header, .file-row { grid-template-columns: minmax(0, 1fr) 76px 18px; gap: 8px; padding-left: 11px; padding-right: 11px; }
    .file-table-header > :nth-child(2), .file-type { display: none; }
    .pagination { justify-content: center; }
    .content-editor.mode-split { grid-template-columns: 1fr; }
